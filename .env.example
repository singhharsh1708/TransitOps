# PostgreSQL connection (pooled URL for the app runtime).
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
# Direct (non-pooling) connection used by Prisma for schema push/migrations.
DIRECT_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# Secret used to sign session JWTs. Change in production.
JWT_SECRET="change-me-to-a-long-random-string"
